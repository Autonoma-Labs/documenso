{
  "buildCommand": "npm run build && cp -r apps/remix/build/client dist",
  "installCommand": "npm install",
  "framework": null,
  "outputDirectory": "dist",
  "functions": {
    "api/index.mjs": {
      "maxDuration": 60,
      "includeFiles": "apps/remix/build/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.mjs" }
  ]
}
