{
  "buildCommand": "npx turbo run build --force",
  "installCommand": "npm install",
  "framework": null,
  "outputDirectory": "apps/remix/build/client",
  "functions": {
    "api/index.mjs": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "apps/remix/build/server/**,node_modules/**,packages/*/node_modules/**,prisma/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.mjs" }
  ]
}
